<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <form action="calcular" method="POST">
    <input type="text" name="tamanho_senha" placeholder="Tamanho da senha">
    <input type="submit" value="Gerar">
    </form>
    <%if(locals.senha){%>
        <h1> Senha: <%=senha%> </h1> 
    <%}else {%>
        <h1>Digite o tamanho da senha</h1>
    <%}%>
  
</body>
</html>